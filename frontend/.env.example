# ZKNative Frontend Environment Variables
# Copy to .env.local and fill in values

# Polkadot Hub RPC endpoint (Testnet)
NEXT_PUBLIC_RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io

# Deployed contract addresses (Polkadot Hub Westend Testnet)
NEXT_PUBLIC_ZKNATIVE_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PRIVATE_VOTING_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ZKN_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect project ID (get at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Chain ID (Westend Asset Hub = 420420421)
NEXT_PUBLIC_CHAIN_ID=420420421
