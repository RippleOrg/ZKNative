{
  "name": "zknative",
  "version": "0.1.0",
  "private": true,
  "description": "ZKNative — Rust ZK verifier callable from Solidity via PolkaVM FFI",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "compile-circuits": "bash scripts/compile-circuits.sh",
    "generate-proof": "npx ts-node scripts/generate-proof.ts",
    "benchmark": "npx ts-node scripts/benchmark.ts",
    "test:contracts": "cd contracts && forge test -vvv",
    "test:rust": "cd pvm-verifier && cargo test",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/node": "^20.14.2"
  }
}
